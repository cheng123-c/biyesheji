<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.health.assessment.mapper.NotificationMapper">

    <!-- 基础结果映射 -->
    <resultMap id="notificationResultMap" type="com.health.assessment.entity.Notification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="notification_type" property="notificationType"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="read_status" property="readStatus"/>
        <result column="created_at" property="createdAt"/>
        <result column="read_at" property="readAt"/>
    </resultMap>

    <!-- 分页查询用户通知 -->
    <select id="selectByUserIdWithPage" resultMap="notificationResultMap">
        SELECT * FROM t_notification
        WHERE user_id = #{userId}
        <if test="notificationType != null and notificationType != ''">
            AND notification_type = #{notificationType}
        </if>
        <if test="readStatus != null">
            AND read_status = #{readStatus}
        </if>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计用户通知数量 -->
    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM t_notification
        WHERE user_id = #{userId}
        <if test="notificationType != null and notificationType != ''">
            AND notification_type = #{notificationType}
        </if>
        <if test="readStatus != null">
            AND read_status = #{readStatus}
        </if>
    </select>

    <!-- 批量标记为已读 -->
    <update id="batchMarkAsRead">
        UPDATE t_notification
        SET read_status = 1, read_at = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 统计各类型通知数量 -->
    <select id="countByType" resultType="map">
        SELECT
            notification_type,
            COUNT(*) as total_count,
            SUM(CASE WHEN read_status = 0 THEN 1 ELSE 0 END) as unread_count
        FROM t_notification
        WHERE user_id = #{userId}
        GROUP BY notification_type
    </select>

</mapper>

