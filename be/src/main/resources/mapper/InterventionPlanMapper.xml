<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.health.assessment.mapper.InterventionPlanMapper">

    <!-- 基础结果映射 -->
    <resultMap id="interventionPlanResultMap" type="com.health.assessment.entity.InterventionPlan">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="plan_type" property="planType"/>
        <result column="target_disease" property="targetDisease"/>
        <result column="plan_detail" property="planDetail"/>
        <result column="duration_days" property="durationDays"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 分页查询用户干预方案 -->
    <select id="selectByUserIdWithPage" resultMap="interventionPlanResultMap">
        SELECT * FROM t_intervention_plan
        WHERE user_id = #{userId}
        <if test="planType != null and planType != ''">
            AND plan_type = #{planType}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计用户干预方案数量 -->
    <select id="countByUserIdWithCondition" resultType="int">
        SELECT COUNT(*) FROM t_intervention_plan
        WHERE user_id = #{userId}
        <if test="planType != null and planType != ''">
            AND plan_type = #{planType}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
    </select>

    <!-- 查询即将结束的干预方案 -->
    <select id="selectExpiringSoon" resultMap="interventionPlanResultMap">
        SELECT * FROM t_intervention_plan
        WHERE status = 'ACTIVE'
        AND end_date BETWEEN CURDATE() AND DATE_ADD(CURDATE(), INTERVAL #{daysAhead} DAY)
        ORDER BY end_date ASC
    </select>

    <!-- 按状态和类型统计 -->
    <select id="countByStatusAndType" resultType="map">
        SELECT
            status,
            plan_type,
            COUNT(*) as count
        FROM t_intervention_plan
        WHERE user_id = #{userId}
        GROUP BY status, plan_type
    </select>

    <!-- 批量更新已过期方案状态 -->
    <update id="batchExpirePlans">
        UPDATE t_intervention_plan
        SET status = 'COMPLETED'
        WHERE status = 'ACTIVE'
        AND end_date &lt; CURDATE()
    </update>

</mapper>

